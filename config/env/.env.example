# Copy to config/env/.env and fill with production secrets.

# Runtime profile
GB_ENVIRONMENT=production
GB_APP_VERSION=0.1.0
GB_API_PREFIX=/api/v1
GB_HEARTBEAT_INTERVAL_SECONDS=15

# API authentication
GB_API_AUTH_TOKEN=replace-with-long-random-token
GB_API_AUTH_SCOPE=control-plane:full

# Datastore credentials
POSTGRES_DB=gooberberg
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password

# Optional profile overrides
API_BIND_PORT=8000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
